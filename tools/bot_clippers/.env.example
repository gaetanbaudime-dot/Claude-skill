# Copie ce fichier en `.env` puis remplis les valeurs. Ne JAMAIS commiter le .env.

# ---- Bot DISCORD (le bot principal — bot_discord.py) ----

# Token du bot Discord (Developer Portal → ton application → Bot → Reset Token)
DISCORD_TOKEN=

# Clé API Claude (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# ID du canal Discord où le bot répond à TOUT message (clic droit sur le canal → Copier l'identifiant,
# après avoir activé le mode développeur dans Discord). Laisse vide pour qu'il ne réponde que
# lorsqu'on le @mentionne.
CANAL_BOT_ID=

# (Optionnel, recommandé) ID d'un salon FORUM. Le bot répond dans chaque post ET le range
# automatiquement par sujet, à condition d'avoir créé ces tags dans le forum :
# Comptes · Warm-up · Reels · Routine · Blocages · Stratégie · Hors kit
# (clic droit sur le forum → Copier l'identifiant). Pour l'auto-tri, donne au bot la permission
# « Gérer les publications » sur ce forum ; sinon il répond quand même, sans poser le tag.
FORUM_BOT_ID=

# Ton (tes) identifiant(s) Discord, pour les commandes !stats et !apprendre.
# Clic droit sur ton profil → Copier l'identifiant. Plusieurs admins séparés par des virgules.
ADMIN_IDS=

# Optionnel — modèle. Par défaut claude-haiku-4-5 (rapide, ~gratuit, largement assez pour la FAQ).
# MODELE=claude-opus-4-8   # décommente pour des réponses plus fines (5x plus cher)

# Optionnel — questions max par clipper et par jour (30 par défaut)
# QUESTIONS_MAX_PAR_JOUR=30

# Dossier des données persistantes (compteur public, paiements, bumps, FAQ apprise, quotas).
# En local : laisser vide (utilise ./donnees). Sur Railway : DONNEES_DIR=/data + un VOLUME monté
# sur /data — ⚠️ sans ça, TOUS les compteurs sont remis à zéro à chaque déploiement (vécu le 17/07).
# DONNEES_DIR=

# ---- v2 : programme clippers (compteur, paiements, invitations, rangs) ----

# Canal des paiements/wins (#dopamine) : le bot y poste les !paiement et y épingle
# le compteur « X € versés ». Clic droit sur le canal → Copier l'identifiant.
CANAL_DOPAMINE_ID=

# Canal d'accueil des candidats (#candidature) : bienvenue numérotée + attribution du parrain.
CANAL_CANDIDATURE_ID=

# Lien du formulaire de candidature (mis dans le message de bienvenue).
LIEN_FORMULAIRE=

# ⚠️ ACTIVER_V2=1 allume le tracking d'invitations + l'accueil automatique.
# AVANT de le mettre à 1 : Developer Portal → Bot → activer « SERVER MEMBERS INTENT »,
# et donner au bot la permission « Gérer le serveur » (lecture des invitations).
# Sans ces deux prérequis, le bot NE DÉMARRE PAS avec ACTIVER_V2=1.
# ACTIVER_V2=1

# ---- Salons-compteurs (titres auto, comme House of Aphrodite mais vrais chiffres) ----
# Crée une catégorie verrouillée « STATS » avec des salons VOCAUX (personne ne peut s'y connecter) ;
# le bot renomme leur TITRE toutes les 10 min. Permission requise : « Gérer les salons ».
# ID du salon « 💸 Déjà payés : X € » (alimenté par les !paiement) :
CANAL_STAT_PAYES_ID=
# ID du salon « 🎬 Clippers : N » (compte les membres du rôle ci-dessous ; exige ACTIVER_V2=1) :
CANAL_STAT_CLIPPERS_ID=
# Nom du/des rôle(s) comptés pour « Clippers », séparés par des virgules :
# ROLE_CLIPPER_NOM=Rookie,Confirmé,Élite

# ---- Rappel de /bump Disboard ----
# Canal où le bot rappelle quand le /bump est disponible (cooldown Disboard = 2 h) et remercie
# le bumpeur. JAMAIS d'auto-bump (interdit Discord + Disboard) : le bot rappelle, un humain tape /bump.
# Prérequis : le bot DISBOARD ajouté au serveur (disboard.org).
CANAL_BUMP_ID=

# ---- (ancien) Bot TELEGRAM — bot.py, gardé en option, pas utilisé si tu es sur Discord ----
# TELEGRAM_TOKEN=
# CODE_ACCES=

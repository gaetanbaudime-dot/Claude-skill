# Copie ce fichier en `.env` puis remplis les valeurs. Ne JAMAIS commiter le .env.

# Token donné par @BotFather sur Telegram
TELEGRAM_TOKEN=

# Clé API Claude (console.anthropic.com → API Keys)
ANTHROPIC_API_KEY=

# Code d'accès que tu donnes aux clippers (choisis-le toi-même, change-le pour révoquer)
CODE_ACCES=

# Ton identifiant Telegram (pour les commandes /stats et /apprendre).
# Pour le connaître : envoie /start à @userinfobot sur Telegram, il te donne ton id.
# Plusieurs admins possibles, séparés par des virgules.
ADMIN_IDS=

# Optionnel — modèle utilisé (claude-opus-4-8 par défaut ; claude-haiku-4-5 = ~5x moins cher)
# MODELE=claude-opus-4-8

# Optionnel — questions max par clipper et par jour (30 par défaut)
# QUESTIONS_MAX_PAR_JOUR=30

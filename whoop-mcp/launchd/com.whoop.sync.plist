<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Sync quotidien automatique de WHOOP vers whoop.db (macOS launchd).
  On passe par un shell de login (/bin/zsh -lc) pour que `uv` soit trouvé via le PATH.
  Installation :
    cp whoop-mcp/launchd/com.whoop.sync.plist ~/Library/LaunchAgents/
    launchctl load  ~/Library/LaunchAgents/com.whoop.sync.plist
    launchctl start com.whoop.sync   # lancement de test immédiat
  Logs : ~/.whoop-mcp/sync.log
-->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.whoop.sync</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>uv run --python 3.11 --script "$HOME/.whoop-mcp/sync.py" &gt;&gt; "$HOME/.whoop-mcp/sync.log" 2&gt;&amp;1</string>
  </array>

  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key><integer>7</integer>
    <key>Minute</key><integer>30</integer>
  </dict>

  <key>RunAtLoad</key>
  <false/>

  <key>StandardErrorPath</key>
  <string>/tmp/com.whoop.sync.err</string>
  <key>StandardOutPath</key>
  <string>/tmp/com.whoop.sync.out</string>
</dict>
</plist>
